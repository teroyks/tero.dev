---
layout: layouts/base.njk
pagination:
  data: collections
  size: 1
  alias: tag
  filter:
    - all
    - nav
    - post
    - posts
    - blog
permalink: "/tags/{{ tag }}/"
eleventyComputed:
  title: "Tagged: {{ tag }}"
eleventyExcludeFromCollections: true
---

{% from "components/post-date.njk" import postDate %}
{% set posts = collections[tag] | reverse %}

{% for post in posts %}
  <article>
    <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
    {{ postDate(post.date) }}
    {% if post.data.description %}
      <p>{{ post.data.description }}</p>
    {% endif %}
  </article>
{% else %}
  <p>No posts with this tag.</p>
{% endfor %}
